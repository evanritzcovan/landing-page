# Copy this file to `.env.local` and adjust values.
# Next.js loads `.env.local` for local dev (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables)
#
# Do not put secrets in `NEXT_PUBLIC_*` variables—they are exposed to the browser.

# Canonical site URL (no trailing slash). Used for metadataBase, sitemap, and Open Graph.
# Set to your production domain on Vercel (e.g. https://evanritzcovan.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email shown on the contact section (mailto). Safe as a public value.
NEXT_PUBLIC_CONTACT_EMAIL=your-email@example.com
